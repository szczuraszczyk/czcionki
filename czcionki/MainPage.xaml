<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="czcionki.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25"
            Margin="20">

            <Label
                Text="Właściwości czcionki"
                BackgroundColor="#558B2F"
                TextColor="white"
                FontSize="Title"
                HorizontalOptions="Fill"
                FontAttributes="Bold"/>

            <Label
                x:Name="rozmiarNapis"
                Text="Rozmiar: 1"
                FontSize="Medium"
                HorizontalOptions="Fill"/>

            <Slider
                x:Name="slider"
                Minimum="1"
                Maximum="40"
                HorizontalOptions="Fill"
                ValueChanged="Slider_Zmieniony"/>

            <Label 
                x:Name="cytatNapis"
                Text="Dzień dobry"
                HorizontalOptions="Fill"
                FontSize="16"/>

            <Button
                x:Name="strzalkiPrzycisk"
                Text=">>" 
                HorizontalOptions="Center"
                BackgroundColor="#558B2F"
                TextColor="white"
                Clicked="OnClick"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>